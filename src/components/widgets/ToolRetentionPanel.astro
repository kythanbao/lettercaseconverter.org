---
import { findToolByPath, getRelatedTools, getToolCatalog } from '~/utils/tool-catalog';

const { currentPath } = Astro.props as { currentPath: string };

const currentTool = findToolByPath(currentPath);
const relatedTools = getRelatedTools(currentPath, 6);
const toolCatalog = getToolCatalog();
---

{
  currentTool && (
    <section
      id="tool-retention-panel"
      class="not-prose max-w-7xl mx-auto px-4 sm:px-6 py-8 md:py-10"
      data-current-tool={currentTool.href}
      data-current-tool-name={currentTool.name}
    >
      <div class="rounded-2xl border border-slate-200 bg-white p-4 md:p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-xl md:text-2xl font-semibold tracking-tight dark:text-slate-100">Keep Your Workflow Moving</h2>
            <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
              Save favorite tools, reopen recently used tools, and continue with related guides.
            </p>
          </div>
          <button
            type="button"
            data-retention-action="toggle-favorite"
            class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-primary hover:text-primary dark:border-slate-700 dark:text-slate-200"
            aria-pressed="false"
          >
            Save to Favorites
          </button>
        </div>

        <div class="mt-5 grid gap-4 lg:grid-cols-3">
          <article class="rounded-xl border border-slate-200 p-4 dark:border-slate-700">
            <h3 class="font-medium dark:text-slate-100">Recently Used Tools</h3>
            <ul class="mt-3 space-y-2 text-sm" data-retention-list="recent">
              <li class="text-slate-500 dark:text-slate-400">No recent tools yet.</li>
            </ul>
          </article>

          <article class="rounded-xl border border-slate-200 p-4 dark:border-slate-700">
            <h3 class="font-medium dark:text-slate-100">Favorite Tools</h3>
            <ul class="mt-3 space-y-2 text-sm" data-retention-list="favorites">
              <li class="text-slate-500 dark:text-slate-400">No favorites saved yet.</li>
            </ul>
          </article>

          <article class="rounded-xl border border-slate-200 p-4 dark:border-slate-700">
            <h3 class="font-medium dark:text-slate-100">Related Next Steps</h3>
            <ul class="mt-3 space-y-2 text-sm">
              {relatedTools.map((tool) => (
                <li>
                  <a class="text-primary hover:underline" href={tool.href}>
                    {tool.name}
                  </a>
                </li>
              ))}
              <li class="pt-2 text-xs text-slate-500 dark:text-slate-400">Minimal tool set active.</li>
            </ul>
          </article>
        </div>
      </div>

      <script is:inline type="application/json" data-tool-catalog set:html={JSON.stringify(toolCatalog)} />

      <script is:inline>
        function initToolRetentionPanel() {
          const root = document.getElementById('tool-retention-panel');
          if (!root || root.dataset.bound === '1') return;
          root.dataset.bound = '1';

          const currentHref = (root.dataset.currentTool || '').trim();
          if (!currentHref) return;

          const favoriteButton = root.querySelector('[data-retention-action="toggle-favorite"]');
          const recentList = root.querySelector('[data-retention-list="recent"]');
          const favoriteList = root.querySelector('[data-retention-list="favorites"]');
          const catalogEl = root.querySelector('[data-tool-catalog]');

          if (!favoriteButton || !recentList || !favoriteList || !catalogEl) return;

          const RECENT_KEY = 'lcc_recent_tools_v1';
          const FAVORITE_KEY = 'lcc_favorite_tools_v1';
          const MAX_RECENT = 8;
          const MAX_FAVORITES = 16;

          let catalog = [];
          try {
            catalog = JSON.parse(catalogEl.textContent || '[]');
          } catch (_error) {
            catalog = [];
          }

          const normalizePath = (value) => {
            if (!value) return '/';
            return value.split('#')[0].split('?')[0].replace(/\/+$/, '') || '/';
          };

          const readJson = (key, fallback) => {
            try {
              const raw = localStorage.getItem(key);
              if (!raw) return fallback;
              const parsed = JSON.parse(raw);
              return Array.isArray(parsed) ? parsed : fallback;
            } catch (_error) {
              return fallback;
            }
          };

          const writeJson = (key, value) => {
            try {
              localStorage.setItem(key, JSON.stringify(value));
            } catch (_error) {
              // Ignore quota/storage errors in lightweight retention widget.
            }
          };

          const findTool = (href) => {
            const normalized = normalizePath(href);
            return catalog.find((item) => normalizePath(item.href) === normalized);
          };

          const upsertRecent = () => {
            const now = Date.now();
            const current = readJson(RECENT_KEY, []);
            const filtered = current.filter((item) => normalizePath(item.href) !== normalizePath(currentHref));
            const next = [{ href: currentHref, ts: now }, ...filtered].slice(0, MAX_RECENT);
            writeJson(RECENT_KEY, next);
            return next;
          };

          const readFavorites = () => readJson(FAVORITE_KEY, []).map((href) => normalizePath(String(href)));

          const writeFavorites = (favorites) => writeJson(FAVORITE_KEY, favorites.slice(0, MAX_FAVORITES));

          const setFavoriteButtonState = (isFavorite) => {
            favoriteButton.setAttribute('aria-pressed', String(isFavorite));
            favoriteButton.textContent = isFavorite ? 'Saved in Favorites' : 'Save to Favorites';
          };

          const renderList = (target, items, emptyText) => {
            target.innerHTML = '';
            if (!items.length) {
              const li = document.createElement('li');
              li.className = 'text-slate-500 dark:text-slate-400';
              li.textContent = emptyText;
              target.appendChild(li);
              return;
            }

            items.forEach((item) => {
              const li = document.createElement('li');
              const link = document.createElement('a');
              link.className = 'text-primary hover:underline';
              link.href = item.href;
              link.textContent = item.name;
              li.appendChild(link);
              target.appendChild(li);
            });
          };

          const refresh = () => {
            const recent = readJson(RECENT_KEY, [])
              .map((entry) => findTool(entry.href))
              .filter(Boolean)
              .slice(0, MAX_RECENT);

            const favorites = readFavorites()
              .map((href) => findTool(href))
              .filter(Boolean)
              .slice(0, MAX_FAVORITES);

            renderList(recentList, recent, 'No recent tools yet.');
            renderList(favoriteList, favorites, 'No favorites saved yet.');

            const isFavorite = readFavorites().includes(normalizePath(currentHref));
            setFavoriteButtonState(isFavorite);
          };

          upsertRecent();
          refresh();

          favoriteButton.addEventListener('click', () => {
            const normalizedCurrent = normalizePath(currentHref);
            const favorites = readFavorites();
            const exists = favorites.includes(normalizedCurrent);
            const next = exists ? favorites.filter((item) => item !== normalizedCurrent) : [normalizedCurrent, ...favorites];
            writeFavorites(next);
            refresh();
          });
        }

        document.addEventListener('DOMContentLoaded', initToolRetentionPanel);
        document.addEventListener('astro:page-load', initToolRetentionPanel);
      </script>
    </section>
  )
}
