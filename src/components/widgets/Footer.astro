---
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { secondaryLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;

const toSectionId = (value?: string): string =>
  (value || 'tools')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '') || 'tools';

const getFooterListClass = () => 'text-sm grid grid-cols-1 sm:grid-cols-2 gap-x-5';
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative border-t border-gray-200 dark:border-slate-800 not-prose']}>
  <div class="dark:bg-dark absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div
    class="relative max-w-7xl mx-auto px-4 sm:px-6 dark:text-slate-300 intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
  >
    <div class="grid grid-cols-12 gap-4 gap-y-8 sm:gap-8 py-8 md:py-12">
      <div class="col-span-12 lg:col-span-12">
        <div class="mb-2">
          <a class="inline-block font-bold text-xl" href={getHomePermalink()}>
            <span
              class="self-center ml-2 rtl:ml-0 rtl:mr-2 text-xl md:text-xl font-bold text-gray-900 whitespace-nowrap dark:text-white"
            >
              <div class="flex flex-wrap justify-center items-center">
                <div class="w-[60px] h-[60px] flex">
                  <svg
                    class="w-full h-full"
                    width="64"
                    height="64"
                    viewBox="0 0 64 64"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <rect x="4" y="4" width="56" height="56" rx="12" fill="#2563EB"></rect>
                    <text
                      x="32"
                      y="40"
                      text-anchor="middle"
                      font-size="24"
                      font-family="Inter, ui-sans-serif, system-ui"
                      font-weight="700"
                      fill="#ffffff"
                    >
                      &#123;Aa&#125;
                    </text>
                  </svg>
                </div>

                <div class="ml-1 flex flex-col leading-none">
                  <div>Letter</div>
                  <div>Case Converter</div>
                </div>
              </div>
            </span>
          </a>
        </div>
        <nav class="mt-3" aria-label="Footer legal links">
          <ul class="flex flex-wrap gap-x-3 gap-y-1 text-sm text-muted">
            {
              secondaryLinks.map(({ text, href }) => (
                <li>
                  <a
                    class="text-muted hover:text-gray-700 dark:text-gray-400 hover:underline transition duration-150 ease-in-out"
                    href={href}
                    set:html={text}
                  />
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
      <nav class="col-span-12" aria-label="Footer navigation">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 xl:grid-cols-3">
          {
            links.map(({ title, links }) => {
              const maxVisibleLinks = links.length;
              const visibleLinks = links.slice(0, maxVisibleLinks);
              const hasCollapsedLinks = visibleLinks.length < links.length;
              const viewAllLabel =
                title && title.toLowerCase().includes('tool') ? `View all ${title}` : `View all ${title || 'tools'}`;

              return (
                <section>
                  <h2 class="dark:text-gray-300 font-medium mb-2 text-sm uppercase tracking-wide">{title}</h2>
                  {links && Array.isArray(links) && links.length > 0 && (
                    <>
                      <ul class:list={[getFooterListClass()]}>
                        {visibleLinks.map(({ text, href, ariaLabel }) => (
                          <li class="mb-2">
                            <a
                              class="text-muted hover:text-gray-700 hover:underline dark:text-gray-400 transition duration-150 ease-in-out"
                              href={href}
                              aria-label={ariaLabel}
                            >
                              <Fragment set:html={text} />
                            </a>
                          </li>
                        ))}
                      </ul>
                      {
                        hasCollapsedLinks && (
                          <p class="mt-1 text-sm">
                            <a
                              class="font-semibold text-primary hover:underline transition duration-150 ease-in-out"
                              href={`/tools#${toSectionId(title)}`}
                            >
                              {viewAllLabel}
                            </a>
                          </p>
                        )
                      }
                    </>
                  )}
                </section>
              );
            })
          }
        </div>
      </nav>
    </div>
    <div class="md:flex md:items-center md:justify-between py-6 md:py-8">
      <div class="text-sm mr-4 dark:text-muted">
        <Fragment set:html={footNote} />
      </div>
    </div>
  </div>
</footer>
