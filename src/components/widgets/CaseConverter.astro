---
import { Icon } from 'astro-icon/components';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  id,
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<section class="relative not-prose" {...id ? { id } : {}}>
  <!-- BACKGROUND -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <slot name="bg">
      {bg ? <Fragment set:html={bg} /> : null}
    </slot>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="py-8 md:py-15">
      <!-- HEADER -->
      <div class="text-center pb-4 md:pb-8 max-w-7xl mx-auto">
        {
          title && (
            <h1
              class="text-3xl md:text-5xl font-bold leading-tighter tracking-tighter mb-4 font-heading dark:text-gray-200 intersect-once intersect-quarter"
              set:html={title}
            />
          )
        }

        {
          subtitle && (
            <p
              class="text-l md:text-l md:text-xl text-muted dark:text-slate-300 intersect-once intersect-quarter"
              set:html={subtitle}
            />
          )
        }
      </div>

      <!-- TOOL BODY -->
      <div class="max-w-7xl mx-auto intersect-once intersect-quarter">
        <div
          class="rounded-2xl border border-slate-200 bg-white p-2 md:p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900"
        >
          <!-- INPUT -->
          <label class="sr-only" for="cc-input">Text to convert</label>
          <textarea
            id="cc-input"
            placeholder="Paste or type your text here…"
            class="w-full min-h-[200px] resize-y rounded-lg border border-slate-300 p-2 focus:outline-none focus:ring-2 focus:ring-primary dark:border-slate-700 dark:bg-slate-800"
          ></textarea>

          <!-- COUNTERS -->
          <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-sm text-slate-600 dark:text-slate-400">
            <span>Characters: <strong id="cc-chars">0</strong></span>
            <span>Words: <strong id="cc-words">0</strong></span>
            <span>Sentences: <strong id="cc-sentences">0</strong></span>
            <span>Lines: <strong id="cc-lines">0</strong></span>
          </div>

          <!-- ACTION BUTTONS -->
          <div class="mt-4 flex flex-row flex-wrap gap-3">
            <button class="cc-btn btn-primary" data-action="sentence">Sentence case</button>
            <button class="cc-btn btn-primary" data-action="lower">lower case</button>
            <button class="cc-btn btn-primary" data-action="upper">UPPER CASE</button>
            <button class="cc-btn btn-primary" data-action="capitalize">Capitalized Case</button>
            <button class="cc-btn btn-primary" data-action="alternating">aLtErNaTiNg cAsE</button>
            <button class="cc-btn btn-primary" data-action="title">Title Case</button>
            <button class="cc-btn btn-primary" data-action="inverse">InVeRsE CaSe</button>

            <button
              class="cc-btn btn-primary bg-slate-200 text-slate-700 hover:bg-slate-300 dark:bg-slate-700 dark:text-slate-200"
              data-action="clear"
            >
              Clear
            </button>
          </div>
        </div>

        <!-- COPY / DOWNLOAD -->
        <div class="mt-3 flex justify-center">
          <button type="button" class="btn-primary cursor-pointer flex items-center gap-2" data-action="copy">
            <span class="js-text">Copy Text</span>
            <Icon name="tabler:copy" class="w-5 h-5" />
          </button>

          <button type="button" class="btn-secondary ml-2" data-action="download"> Download Text </button>
        </div>
      </div>
    </div>
  </div>

  <!-- SCRIPT -->
  <script is:inline>
    function initCaseConverter() {
      const root = document.getElementById('converter');
      if (!root) return;

      if (root.dataset.initialized === 'true') return;
      root.dataset.initialized = 'true';

      const input = root.querySelector('#cc-input');
      if (!input) return;

      const charsEl = root.querySelector('#cc-chars');
      const wordsEl = root.querySelector('#cc-words');
      const sentencesEl = root.querySelector('#cc-sentences');
      const linesEl = root.querySelector('#cc-lines');

      function updateCounters(text) {
        charsEl.textContent = text.length;
        wordsEl.textContent = text.trim() ? text.trim().split(/\s+/).length : 0;
        sentencesEl.textContent = text.trim() ? text.split(/[.!?]+/).filter(Boolean).length : 0;
        linesEl.textContent = text ? text.split(/\r\n|\r|\n/).length : 0;
      }

      function sentenceCase(text) {
        return text.toLowerCase().replace(/(^\s*\w|[.!?]\s*\w)/g, (c) => c.toUpperCase());
      }

      function titleCase(text) {
        return text.toLowerCase().replace(/\b\w/g, (c) => c.toUpperCase());
      }

      function alternatingCase(text) {
        let upper = true;
        return text
          .split('')
          .map((c) => {
            if (!/[a-z]/i.test(c)) return c;
            const out = upper ? c.toUpperCase() : c.toLowerCase();
            upper = !upper;
            return out;
          })
          .join('');
      }

      function inverseCase(text) {
        return text
          .split('')
          .map((c) => {
            if (!/[a-z]/i.test(c)) return c;
            return c === c.toUpperCase() ? c.toLowerCase() : c.toUpperCase();
          })
          .join('');
      }
      function downloadText(text) {
        if (!text) return;
        const blob = new Blob(['\uFEFF' + text], {
          type: 'text/plain;charset=utf-8',
        });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `letter-case-converter-${Date.now()}.txt`;
        a.click();
        URL.revokeObjectURL(url);
      }

      input.addEventListener('input', () => updateCounters(input.value));

      root.querySelectorAll('[data-action]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const action = btn.dataset.action;
          const text = input.value;

          switch (action) {
            case 'sentence':
              input.value = sentenceCase(text);
              break;
            case 'lower':
              input.value = text.toLowerCase();
              break;
            case 'upper':
              input.value = text.toUpperCase();
              break;
            case 'capitalize':
            case 'title':
              input.value = titleCase(text);
              break;
            case 'alternating':
              input.value = alternatingCase(text);
              break;
            case 'inverse':
              input.value = inverseCase(text);
              break;
            case 'copy':
              if (!text) return;
              await navigator.clipboard.writeText(text);
              return;
            case 'download':
              downloadText(text);
              return;
            case 'clear':
              input.value = '';
              updateCounters('');
              return;
          }

          updateCounters(input.value);
        });
      });

      updateCounters(input.value);
    }

    document.addEventListener('DOMContentLoaded', initCaseConverter);
    document.addEventListener('astro:page-load', initCaseConverter);
  </script>

  <style>
    .cc-btn {
      @apply rounded-lg px-2 py-1;
    }
  </style>
</section>
