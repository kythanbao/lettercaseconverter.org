---
import { Icon } from 'astro-icon/components';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  id,
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<section class="relative not-prose" {...id ? { id } : {}}>
  <!-- BACKGROUND -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <slot name="bg">
      {bg ? <Fragment set:html={bg} /> : null}
    </slot>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="py-10 md:py-15">
      <!-- HEADER -->
      <div class="text-center pb-8 max-w-7xl mx-auto">
        {title && (
          <h1
            class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter mb-4 font-heading dark:text-gray-200"
            set:html={title}
          />
        )}
        {subtitle && (
          <p class="text-xl text-muted dark:text-slate-300" set:html={subtitle} />
        )}
      </div>

      <!-- TOOL BODY -->
      <div class="max-w-7xl mx-auto">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
          <!-- INPUT -->
          <label class="mb-2 block text-sm font-medium" for="rt-input">
            Input Text
          </label>
          <textarea
            id="rt-input"
            placeholder="Paste or type your text here…"
            class="w-full min-h-[160px] resize-y rounded-lg border border-slate-300 p-4 dark:border-slate-700 dark:bg-slate-800"
          ></textarea>

          <!-- OPTIONS -->
          <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-3 text-sm">
            <label class="flex items-center gap-2">
              <input type="radio" name="reverse-mode" value="all" checked />
              Reverse entire text
            </label>

            <label class="flex items-center gap-2">
              <input type="radio" name="reverse-mode" value="words" />
              Reverse each word
            </label>

            <label class="flex items-center gap-2">
              <input type="radio" name="reverse-mode" value="order" />
              Reverse word order
            </label>
          </div>

          <!-- ACTION BUTTONS -->
          <div class="mt-4 flex flex-row flex-wrap gap-3">
            <button class="cc-btn btn-primary" data-action="reverse">
              Reverse Text
            </button>

            <button
              class="cc-btn btn-primary bg-slate-200 text-slate-700 hover:bg-slate-300 dark:bg-slate-700 dark:text-slate-200"
              data-action="clear"
            >
              Clear
            </button>
          </div>

          <!-- OUTPUT -->
          <div class="mt-6">
            <label class="mb-2 block text-sm font-medium" for="rt-output">
              Result
            </label>
            <textarea
              id="rt-output"
              readonly
              class="w-full min-h-[160px] rounded-lg border border-slate-300 bg-slate-100 p-4 dark:border-slate-700 dark:bg-slate-800"
            ></textarea>
          </div>
        </div>

        <!-- COPY BUTTON -->
        <div class="mt-3 flex justify-center">
          <button
            type="button"
            class="btn-primary cursor-pointer flex items-center gap-2"
            data-action="copy"
          >
            <span class="js-text">Copy Result</span>
            <Icon name="tabler:copy" class="w-5 h-5" />
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- SCRIPT -->
  <script is:inline>
    function initTool() {
      const root = document.getElementById('reverse-text-generator');
      if (!root) return;
      if (root.dataset.initialized === 'true') return;
      root.dataset.initialized = 'true';

      const input = document.getElementById('rt-input');
      const output = document.getElementById('rt-output');

      function reverseText(text, mode) {
        if (!text) return '';

        switch (mode) {
          case 'words':
            return text
              .split(/\s+/)
              .map((word) => Array.from(word).reverse().join(''))
              .join(' ');

          case 'order':
            return text
              .split(/\s+/)
              .reverse()
              .join(' ');

          case 'all':
          default:
            return Array.from(text).reverse().join('');
        }
      }

      document.querySelectorAll('[data-action]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const action = btn.dataset.action;

          if (action === 'reverse') {
            const mode =
              root.querySelector('input[name="reverse-mode"]:checked')?.value || 'all';
            output.value = reverseText(input.value, mode);
          }

          if (action === 'copy' && output.value) {
            await navigator.clipboard.writeText(output.value);
            btn.querySelector('.js-text').textContent = 'Copied!';
            setTimeout(() => {
              btn.querySelector('.js-text').textContent = 'Copy Result';
            }, 1200);
          }

          if (action === 'clear') {
            input.value = '';
            output.value = '';
          }
        });
      });
    }

    document.addEventListener('DOMContentLoaded', initTool);
    document.addEventListener('astro:page-load', initTool);
  </script>

  <style>
    .cc-btn {
      @apply rounded-lg p-1;
    }
  </style>
</section>
