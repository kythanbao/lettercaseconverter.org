---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Trust Center',
  description: 'Quality, testing, limitations, and data-handling standards for Letter Case Converter tools.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 sm:px-6 lg:py-16 mx-auto max-w-4xl prose prose-slate dark:prose-invert">
    <h1>Trust Center</h1>
    <p>
      This trust center summarizes how the site validates tools, documents limitations, and handles data. It is
      designed for users, reviewers, and ad-approval teams who need transparent quality signals.
    </p>

    <h2>Core Trust Pages</h2>
    <ul>
      <li>
        <a href="/trust/how-we-test-tools">How We Test Tools</a>
      </li>
      <li>
        <a href="/trust/known-limitations">Known Limitations</a>
      </li>
      <li>
        <a href="/trust/data-handling-summary">Data Handling Summary</a>
      </li>
      <li>
        <a href="/editorial-policy">Editorial Policy / Content Quality</a>
      </li>
    </ul>

    <h2>Policy References</h2>
    <ul>
      <li>
        <a href="/privacy">Privacy Policy</a>
      </li>
      <li>
        <a href="/us-privacy-notice">US State Privacy Notice</a>
      </li>
      <li>
        <a href="/do-not-sell-or-share">Do Not Sell or Share</a>
      </li>
      <li>
        <a href="/privacy-request">Privacy Request Center</a>
      </li>
      <li>
        <a href="/terms">Terms of Service</a>
      </li>
      <li>
        <a href="/cookie-policy">Cookie Policy</a>
      </li>
      <li>
        <a href="/ai-usage-policy">AI Usage Policy</a>
      </li>
    </ul>
  </section>
</Layout>
