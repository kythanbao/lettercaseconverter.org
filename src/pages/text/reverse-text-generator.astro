---
import Layout from '~/layouts/PageLayout.astro';
import ReverseTextGeneratorWidget from '~/components/widgets/ReverseTextGenerator.astro';

export const prerender = true;


const metadata = {
  title: 'Reverse Text Generator — Reverse Text Online',
  description: 'Reverse text, reverse each word, or reverse word order instantly. Free online reverse text generator.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <ReverseTextGeneratorWidget id="reverse-text-generator">
    <Fragment slot="title">Reverse Text Generator</Fragment>

    <Fragment slot="subtitle">
      Reverse text instantly by characters, by words, or by word order using this free online tool.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </ReverseTextGeneratorWidget>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 pb-8 md:pb-12 not-prose">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 md:p-7 shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-2xl font-semibold tracking-tight dark:text-slate-100">Introduction</h2>
      <p class="mt-3 text-slate-700 dark:text-slate-300">
        Reverse Text Generator supports three practical modes: reverse full text, reverse each word, and reverse word order.
        It is useful for quick text experiments, puzzle-style transformations, and testing string handling behavior.
      </p>

      <h3 class="mt-6 text-xl font-semibold tracking-tight dark:text-slate-100">Reference Sample</h3>
      <pre class="mt-2 overflow-x-auto rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm dark:border-slate-700 dark:bg-slate-800"><code>Input:
Hello world

Mode: Reverse entire text
Output:
dlrow olleH</code></pre>

      <h3 class="mt-6 text-xl font-semibold tracking-tight dark:text-slate-100">How It Works</h3>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-700 dark:text-slate-300">
        <li>Paste text into the input.</li>
        <li>Select one reverse mode.</li>
        <li>Click <strong>Reverse Text</strong> and copy result.</li>
      </ul>

      <h3 class="mt-6 text-xl font-semibold tracking-tight dark:text-slate-100">When Not to Use</h3>
      <p class="mt-2 text-slate-700 dark:text-slate-300">
        Do not use for semantic rewriting. This tool only changes character/word order; it does not preserve meaning.
      </p>
    </div>
  </section>
</Layout>
