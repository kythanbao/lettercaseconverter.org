---
import Layout from '~/layouts/PageLayout.astro';
import RemoveExtraSpacesWidget from '~/components/widgets/RemoveExtraSpaces.astro';

export const prerender = true;


const metadata = {
  title: 'Remove Extra Spaces — Clean Up Text and Whitespace Instantly',
  description:
    'Remove extra spaces, tabs, and inconsistent whitespace from text. Clean up formatting instantly in your browser.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <RemoveExtraSpacesWidget id="remove-extra-spaces" tagline="Free Online Text Tool">
    <Fragment slot="title"> Remove Extra Spaces </Fragment>

    <Fragment slot="subtitle"> Remove extra spaces, unnecessary line breaks, and clean up text instantly. </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
</RemoveExtraSpacesWidget>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 pb-8 md:pb-12 not-prose">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 md:p-7 shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-2xl font-semibold tracking-tight dark:text-slate-100">Introduction</h2>
      <p class="mt-3 text-slate-700 dark:text-slate-300">
        Remove Extra Spaces helps you normalize messy text copied from email, docs, chat, or PDFs. It collapses repeated
        spaces and trims spacing noise around line breaks so your output is clean and ready to paste into CMS, code, or
        spreadsheets.
      </p>

      <h3 class="mt-6 text-xl font-semibold tracking-tight dark:text-slate-100">Reference Sample</h3>
      <pre class="mt-2 overflow-x-auto rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm dark:border-slate-700 dark:bg-slate-800"><code>Input:
Hello     world
This    is    a      test.

Output:
Hello world
This is a test.</code></pre>

      <h3 class="mt-6 text-xl font-semibold tracking-tight dark:text-slate-100">How It Works</h3>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-slate-700 dark:text-slate-300">
        <li>Paste text into the input area.</li>
        <li>Click <strong>Remove Extra Spaces</strong>.</li>
        <li>Review output and copy the cleaned version.</li>
      </ul>

      <h3 class="mt-6 text-xl font-semibold tracking-tight dark:text-slate-100">When Not to Use</h3>
      <p class="mt-2 text-slate-700 dark:text-slate-300">
        Avoid this tool for fixed-width text where exact spacing is meaningful (for example aligned plain-text tables).
      </p>
    </div>
  </section>
</Layout>
