---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Contact Us – Letter Case Converter',
  description:
    'Contact Letter Case Converter for tool support, bug reports, feature requests, and partnerships. We usually respond within 24-48 hours.',
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 sm:px-6 lg:py-16 mx-auto max-w-4xl not-prose">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 md:p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight dark:text-slate-100">Contact the Team</h1>
      <p class="mt-3 text-slate-700 dark:text-slate-300">
        Send support requests, bug reports, and feature ideas. We usually respond within 24-48 hours.
      </p>

      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <article class="rounded-xl border border-slate-200 p-4 dark:border-slate-700">
          <h2 class="font-semibold dark:text-slate-100">General Support</h2>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
            Questions about tool behavior, expected output, or workflow usage.
          </p>
        </article>
        <article class="rounded-xl border border-slate-200 p-4 dark:border-slate-700">
          <h2 class="font-semibold dark:text-slate-100">Bug Reports</h2>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
            Include tool URL, sample input, current output, and expected output.
          </p>
        </article>
      </div>

      <p class="mt-6 text-slate-700 dark:text-slate-300">
        Email: <a class="text-primary hover:underline" href="mailto:contact@lettercaseconverter.org">contact@lettercaseconverter.org</a>
      </p>
      <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
        For privacy-rights requests, use <a class="text-primary hover:underline" href="/privacy-request">Privacy Request Center</a>.
      </p>
    </div>
  </section>
</Layout>
