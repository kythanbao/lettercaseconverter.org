---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Privacy Request Center',
  description:
    'Submit privacy rights requests (access, correction, deletion, Do Not Sell/Share opt-out, and appeal) for Letter Case Converter.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 sm:px-6 lg:py-16 mx-auto max-w-4xl">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100">Privacy Request Center</h1>
      <p class="mt-3 text-slate-700 dark:text-slate-300">
        Use this page to submit data rights requests for US privacy laws, including access, correction, deletion,
        Do Not Sell/Share opt-out, and appeal.
      </p>

      <div class="mt-6 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm text-slate-700 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300">
        <p><strong>Expected response window:</strong> We review valid requests within 45 days (or as required by applicable law).</p>
        <p class="mt-2"><strong>Verification:</strong> We may request additional details to verify identity and protect user data.</p>
      </div>

      <form id="privacy-request-form" class="mt-6 grid gap-4" novalidate>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-800 dark:text-slate-200">Full name</span>
          <input
            required
            name="fullName"
            type="text"
            class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-800"
          />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-800 dark:text-slate-200">Email address</span>
          <input
            required
            name="email"
            type="email"
            class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-800"
          />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-800 dark:text-slate-200">State / region</span>
          <input
            name="region"
            type="text"
            placeholder="e.g. California, United States"
            class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-800"
          />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-800 dark:text-slate-200">Request type</span>
          <select
            required
            name="requestType"
            class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-800"
          >
            <option value="">Select one</option>
            <option value="Access request">Access request</option>
            <option value="Correction request">Correction request</option>
            <option value="Deletion request">Deletion request</option>
            <option value="Do Not Sell/Share opt-out">Do Not Sell/Share opt-out</option>
            <option value="Limit sensitive data request">Limit sensitive data request</option>
            <option value="Appeal request">Appeal request</option>
          </select>
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-800 dark:text-slate-200">Related page or tool URL (optional)</span>
          <input
            name="relatedUrl"
            type="text"
            placeholder="https://lettercaseconverter.org/..."
            class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-800"
          />
        </label>

        <label class="block">
          <span class="mb-1 block text-sm font-medium text-slate-800 dark:text-slate-200">Details</span>
          <textarea
            required
            name="details"
            rows="6"
            placeholder="Describe your request with enough detail for verification and handling."
            class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-800"
          ></textarea>
        </label>

        <div class="mt-2 flex flex-wrap gap-2">
          <button type="submit" class="cc-btn cc-btn-primary">Send request by email</button>
          <a href="mailto:contact@lettercaseconverter.org?subject=Privacy%20Request" class="cc-btn cc-btn-secondary"
            >Open email app</a
          >
        </div>

        <p id="privacy-request-feedback" class="text-sm text-slate-600 dark:text-slate-300" role="status" aria-live="polite"></p>
      </form>

      <div class="mt-8 text-sm text-slate-700 dark:text-slate-300">
        <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Related privacy pages</h2>
        <ul class="mt-2 list-disc pl-5">
          <li><a class="underline" href="/privacy">Privacy Policy</a></li>
          <li><a class="underline" href="/us-privacy-notice">US State Privacy Notice</a></li>
          <li><a class="underline" href="/do-not-sell-or-share">Do Not Sell or Share My Personal Information</a></li>
          <li><a class="underline" href="/cookie-policy">Cookie Policy</a></li>
        </ul>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const form = document.getElementById('privacy-request-form');
      const feedback = document.getElementById('privacy-request-feedback');
      if (!(form instanceof HTMLFormElement) || !(feedback instanceof HTMLElement)) return;

      form.addEventListener('submit', (event) => {
        event.preventDefault();

        const fd = new FormData(form);
        const fullName = String(fd.get('fullName') || '').trim();
        const email = String(fd.get('email') || '').trim();
        const region = String(fd.get('region') || '').trim();
        const requestType = String(fd.get('requestType') || '').trim();
        const relatedUrl = String(fd.get('relatedUrl') || '').trim();
        const details = String(fd.get('details') || '').trim();

        if (!fullName || !email || !requestType || !details) {
          feedback.textContent = 'Please complete required fields before sending.';
          return;
        }

        const subject = `[Privacy Request] ${requestType} - ${fullName}`;
        const body = [
          `Full name: ${fullName}`,
          `Email: ${email}`,
          `State/Region: ${region || 'Not provided'}`,
          `Request type: ${requestType}`,
          `Related URL: ${relatedUrl || 'Not provided'}`,
          '',
          'Details:',
          details,
        ].join('\n');

        const mailto = `mailto:contact@lettercaseconverter.org?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        window.location.href = mailto;
        feedback.textContent = 'Your email app should open with a prefilled request. Send the message to submit your request.';
      });
    })();
  </script>

  <style>
    .cc-btn {
      @apply inline-flex min-h-[38px] items-center justify-center rounded-lg border border-transparent px-3 py-1.5 text-sm font-medium transition duration-150 ease-in-out;
    }

    .cc-btn-primary {
      @apply bg-primary text-white hover:bg-secondary;
    }

    .cc-btn-secondary {
      @apply border-slate-300 bg-slate-100 text-slate-700 hover:bg-slate-200 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700;
    }
  </style>
</Layout>
