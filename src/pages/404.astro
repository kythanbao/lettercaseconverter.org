---
import Layout from '~/layouts/PageLayout.astro';
import { getHomePermalink } from '~/utils/permalinks';

const metadata = {
  title: '404 – Page Not Found',
  description:
    'The page you are looking for could not be found. Return to the Letter Case Converter homepage to continue.',
  robots: { index: false, follow: false },
};
---

<Layout metadata={metadata}>
  <section class="flex items-center justify-center min-h-[70vh] px-6 py-16">
    <div class="max-w-md text-center">
      <h1 class="mb-6 font-extrabold text-9xl text-primary">404</h1>

      <p class="text-2xl font-semibold mb-3">Page not found</p>

      <p class="text-muted dark:text-slate-400 mb-8">
        The page you’re looking for doesn’t exist or may have been moved. Let’s get you back on track.
      </p>

      <a href={getHomePermalink()} class="btn btn-primary"> Back to homepage </a>
    </div>
  </section>
</Layout>
