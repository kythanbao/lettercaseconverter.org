---
import Layout from '~/layouts/PageLayout.astro';
import CaseConverter from '~/components/widgets/CaseConverter.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Letter Case Converter — Minimal Tool Set',
  description: 'Letter Case Converter with a minimal set of text tools.',
  ignoreTitleTemplate: true,
};

const tools = [
  {
    name: 'Remove Extra Spaces',
    href: getPermalink('/cleanup/remove-extra-spaces'),
    description: 'Collapse repeated spaces and clean pasted text quickly.',
  },
  {
    name: 'Reverse Text Generator',
    href: getPermalink('/text/reverse-text-generator'),
    description: 'Reverse text by full string, word order, or word characters.',
  },
];
---

<Layout metadata={metadata}>
  <CaseConverter id="converter" tagline="Core Tool">
    <Fragment slot="title">Letter Case Converter</Fragment>
    <Fragment slot="subtitle">
      Convert letter case instantly. The site is currently streamlined to a minimal tool set.
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </CaseConverter>

  <section class="max-w-7xl mx-auto px-4 py-8 md:py-10">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 class="text-2xl font-semibold tracking-tight dark:text-slate-100">Available Tools</h2>
          <p class="text-sm text-slate-600 dark:text-slate-400">Only two additional tools are kept active.</p>
        </div>
        <a href={getPermalink('/tools')} class="text-sm text-primary hover:underline">Open tools directory →</a>
      </div>
      <ul class="mt-4 grid gap-3 md:grid-cols-2">
        {tools.map((tool) => (
          <li>
            <a
              href={tool.href}
              class="block rounded-xl border border-slate-200 bg-white p-4 hover:border-primary dark:border-slate-700 dark:bg-slate-900"
            >
              <h3 class="font-semibold dark:text-slate-100">{tool.name}</h3>
              <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">{tool.description}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>
